# ============================================================================
# tradingbots-fun Data Feeds Configuration
# ============================================================================
#
# STRUCTURE: This file shows ALL configuration options
# VALUE: The endpoints and settings are PUBLIC and shareable
# SECURITY: API KEYS (if needed) go in .env.data-feeds.private
#
# Copy to .env.data-feeds and fill in values from .env.data-feeds.private
#
# ============================================================================

# ============================================================================
# PRIMARY DATA SOURCES - PUBLIC ENDPOINTS
# ============================================================================
# These endpoints are FREE and require NO AUTHENTICATION
# All of these are safe to share and document publicly

# BINANCE API - Recommended Primary Source
# Endpoint: https://api.binance.com/api/v3
# Rate Limit: 1200 requests/minute
# Authentication: NOT required (public data)
# Cost: $0/month forever
BINANCE_BASE_URL=https://api.binance.com/api/v3
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_ENABLED=true
BINANCE_RATE_LIMIT=1200
BINANCE_TIMEOUT_SECS=10

# COINGECKO API - Fallback Source
# Endpoint: https://api.coingecko.com/api/v3
# Rate Limit: 50 requests/minute (free tier)
# Authentication: NOT required for free tier
# Cost: $0/month forever
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_ENABLED=true
COINGECKO_RATE_LIMIT=50
COINGECKO_TIMEOUT_SECS=15

# KRAKEN API - Alternative Source
# Endpoint: https://api.kraken.com/0/public
# Rate Limit: 15 requests/second (900/minute)
# Authentication: NOT required for public data
# Cost: $0/month forever
KRAKEN_BASE_URL=https://api.kraken.com/0/public
KRAKEN_ENABLED=true
KRAKEN_RATE_LIMIT=900
KRAKEN_TIMEOUT_SECS=10

# HYPERLIQUID API - Your Trading Venue (Most Important!)
# Endpoint: https://api.hyperliquid.com/info
# Rate Limit: UNLIMITED (no rate limit for public data)
# Authentication: NOT required for public market data
# Cost: $0 (you use it anyway for trading)
HYPERLIQUID_FEED_URL=https://api.hyperliquid.com/info
HYPERLIQUID_FEED_WS=wss://api.hyperliquid.com/ws
HYPERLIQUID_FEED_ENABLED=true
HYPERLIQUID_FEED_RATE_LIMIT=0
HYPERLIQUID_TIMEOUT_SECS=10

# POLYGON.IO API - Optional Aggregate Data
# Endpoint: https://api.polygon.io/v1
# Rate Limit: 5 requests/minute (free tier)
# Authentication: REQUIRES API KEY (see .env.data-feeds.private)
# Cost: $0/month (free tier with limits)
POLYGON_BASE_URL=https://api.polygon.io/v1
POLYGON_ENABLED=false
POLYGON_RATE_LIMIT=300
POLYGON_TIMEOUT_SECS=15

# ============================================================================
# TRADING SYMBOLS - Which pairs to fetch prices for
# ============================================================================

# Comma-separated list of trading pairs
# For CEX: Use format like SOLUSDT, BTCUSDT, ETHUSDT
# For DEX: Use format like SOL/USD, BTC/USD
TRADING_SYMBOLS=SOLUSDT,BTCUSDT,ETHUSDT

# Coin IDs for APIs that use different naming
# (CoinGecko uses these: solana, bitcoin, ethereum)
COINGECKO_COIN_IDS=solana,bitcoin,ethereum

# Kraken uses different pair format (XSOLZUSD, XXBTZUSD)
KRAKEN_PAIR_SYMBOLS=XSOLZUSD,XXBTZUSD,XETHZUSD

# ============================================================================
# PRICING DATA STRATEGY
# ============================================================================

# Primary data source (binance, coingecko, kraken, or hyperliquid)
PRIMARY_DATA_SOURCE=binance

# Fallback data source (if primary is unavailable)
FALLBACK_DATA_SOURCE=coingecko

# How long to cache prices before fetching new ones (milliseconds)
# Lower = more accurate, higher = fewer API calls
PRICE_CACHE_DURATION_MS=500

# How many seconds to wait after primary source fails before trying fallback
FALLBACK_WAIT_SECS=5

# Maximum number of retries for failed API calls
MAX_API_RETRIES=3

# ============================================================================
# HISTORICAL DATA CONFIGURATION
# ============================================================================

# Which API to use for downloading historical OHLCV data
# (binance, coingecko, or kraken)
HISTORICAL_DATA_SOURCE=binance

# Directory to store downloaded historical data
HISTORICAL_DATA_PATH=./data/historical

# How many days of historical data to keep locally
# (older data is deleted to save space)
HISTORICAL_DATA_RETENTION_DAYS=365

# Candle timeframes to fetch (comma-separated)
# Supported: 1m, 5m, 15m, 1h, 4h, 1d
# Note: Backtesting uses these timeframes
CANDLE_TIMEFRAMES=1h,4h,1d

# ============================================================================
# API TIMEOUTS (seconds)
# ============================================================================

# How long to wait for each API call before timing out
BINANCE_TIMEOUT_SECS=10
COINGECKO_TIMEOUT_SECS=15
KRAKEN_TIMEOUT_SECS=10
POLYGON_TIMEOUT_SECS=15
HYPERLIQUID_TIMEOUT_SECS=10

# ============================================================================
# LOGGING & DEBUG
# ============================================================================

# Enable verbose logging for data feed operations
API_DEBUG=false

# Log every API call (warning: very verbose)
API_CALL_LOGGING=false

# Log cache hits/misses (for debugging performance)
CACHE_LOGGING=false

# ============================================================================
# DRIFT PROTOCOL SPECIFIC
# ============================================================================

# NOTE: For Drift RPC calls, use your existing DRIFT_RPC setting
# We avoid polling RPC for prices and only use it for wallet/transactions
# Price data comes from Binance/Hyperliquid instead

DRIFT_RPC=https://api.mainnet-beta.solana.com
DRIFT_COMMITMENT=confirmed

# ============================================================================
# IMPORTANT NOTES
# ============================================================================
#
# 1. NEVER COMMIT THIS FILE TO GIT
#    Use .env.data-feeds.example as the template instead
#
# 2. API KEY SECURITY
#    - Most free APIs don't require keys (Binance, Kraken, Hyperliquid)
#    - CoinGecko doesn't require a key for free tier
#    - If you use Polygon, never commit your key
#
# 3. RATE LIMITS
#    - Binance: 1200 req/min (plenty for real-time trading)
#    - Kraken: 900 req/min (also plenty)
#    - CoinGecko: 50 req/min (use as fallback/backup)
#    - Hyperliquid: No limit (use for venue pricing)
#
# 4. REDUNDANCY
#    - Have at least 2 data sources enabled
#    - Primary fails? Automatic fallback to secondary
#    - Both fail? System will degrade gracefully
#
# 5. CACHING
#    - Prices cached for 500ms = 120 updates/min per symbol
#    - Well within rate limits of all APIs
#    - Ensures fresh data without excessive API calls
#
# 6. REAL-TIME TRADING
#    - Uses PRIMARY_DATA_SOURCE (set to binance)
#    - Cached to respect rate limits
#    - Falls back to FALLBACK_DATA_SOURCE if needed
#
# 7. BACKTESTING
#    - Downloads historical data once
#    - Stores in HISTORICAL_DATA_PATH
#    - No API calls during backtest (uses local data)
#    - You can supply your own OHLCV CSV if preferred
#
# ============================================================================
