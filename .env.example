# =============================================================================
# REDROBOT HEDGEBOT - Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to GitHub - it will expose your API keys!
# =============================================================================

# TRADING MODE
# Options: testnet (free, no risk), mainnet (real money)
MODE=testnet

# TRADING PARAMETERS
TRADING_SYMBOL=SOL
INITIAL_CAPITAL=100
MAX_POSITION_PCT=0.15
MAX_LEVERAGE=15.0
DAILY_LOSS_LIMIT=30.0
MIN_HEALTH_FACTOR=2.0

# =============================================================================
# BINANCE API (CEX ORDER BOOK MONITORING)
# Get keys: https://www.binance.com/en/account/api-management
# =============================================================================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# =============================================================================
# HYPERLIQUID API (DEX TRADING - REAL ORDERS)
# Get keys: https://app.hyperliquid.xyz (Settings → API)
# WARNING: This will execute REAL trades with real money!
# =============================================================================
HYPERLIQUID_KEY=your_hyperliquid_key_here
HYPERLIQUID_SECRET=your_private_key_hex_here
HYPERLIQUID_WALLET_ADDRESS=0xYourWalletAddressHere

# =============================================================================
# BUILDER CODE (PLATFORM REVENUE — OPERATORS ONLY)
# Platform wallet address that earns Hyperliquid builder fees on every order.
# Set once on the server; users never see or interact with this field.
# Every order placed by any user through this platform credits this address.
# Leave blank for pure paper-trading deployments.
# =============================================================================
BUILDER_CODE=0xYourPlatformBuilderAddressHere

# =============================================================================
# REFERRAL CODE (AFFILIATE REVENUE — OPERATORS ONLY)
# Your Hyperliquid referral slug registered at app.hyperliquid.xyz.
# Displayed in the consumer /app page so new users sign up via your link:
#   https://app.hyperliquid.xyz/join/REDROBOT
# Earns 10% of trading fee rebates from all referred users — ongoing passive
# income on top of builder fees, completely invisible to end users.
# Register your code at: https://app.hyperliquid.xyz (Profile → Referrals)
# =============================================================================
REFERRAL_CODE=REDROBOT

# =============================================================================
# STRIPE BILLING (SUBSCRIPTION — OPERATORS ONLY)
# Required to enable the $19.99/month Pro subscription flow.
# Get keys: https://dashboard.stripe.com/apikeys
#
# STRIPE_SECRET_KEY      — server-side secret key (sk_live_… or sk_test_…)
# STRIPE_WEBHOOK_SECRET  — endpoint signing secret (whsec_…)
#                          Set up at: Dashboard → Developers → Webhooks
#                          Listen for: checkout.session.completed,
#                                      customer.subscription.deleted,
#                                      invoice.payment_failed
# STRIPE_PRICE_ID        — recurring price ID for the Pro plan (price_…)
#                          Create at: Dashboard → Products → Add product
# =============================================================================
STRIPE_SECRET_KEY=sk_test_yourKeyHere
STRIPE_WEBHOOK_SECRET=whsec_yourWebhookSecretHere
STRIPE_PRICE_ID=price_yourPriceIdHere

# =============================================================================
# DATABASE
# Default: Local PostgreSQL on localhost
# Production: Use managed PostgreSQL service
# =============================================================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/redrobot

# =============================================================================
# LOGGING
# Options: debug, info, warn, error
# Use 'debug' for troubleshooting, 'info' for production
# =============================================================================
RUST_LOG=info

# =============================================================================
# OPTIONAL: WHALE TRACKING (GMGN)
# Get API key: https://gmgn.ai (optional, free tier available)
# =============================================================================
GMGN_API_KEY=optional_gmgn_key_here

# =============================================================================
# OPTIONAL: CLAUDE AI ANALYSIS
# Get API key: https://console.anthropic.com
# Used for decision validation on edge cases
# =============================================================================
CLAUDE_API_KEY=optional_claude_key_here

# =============================================================================
# SERVER
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# =============================================================================
# DEPLOYMENT ENVIRONMENT
# =============================================================================
DOCKER_IMAGE_TAG=latest
CONTAINER_NAME=redrobot-app

# =============================================================================
# SAFETY LIMITS (ENFORCED - DO NOT CHANGE)
# =============================================================================
# These values are hardcoded and cannot be overridden in production
# Max Position: 15% of capital per trade
# Max Leverage: 15x (scaled by volatility, actual may be lower)
# Min Health Factor: 2.0 (prevents liquidation)
# Daily Loss Limit: $30 (stops trading if hit)
# =============================================================================
