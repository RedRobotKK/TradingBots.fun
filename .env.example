# =============================================================================
# TradingBots.fun — Environment Configuration
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#   nano .env
#
# On a VPS (recommended): add each variable to /etc/environment instead,
# then restart the service: systemctl restart tradingbots
#
# Lines starting with # are comments and are ignored.
# =============================================================================


# =============================================================================
# MODE — Paper, Testnet, or Mainnet
# =============================================================================
# paper   = simulated trades, no real money (default)
# testnet = real orders on Hyperliquid testnet (fake funds)
# mainnet = live trading with real money
MODE=paper

# When MODE=paper this is forced true. Set false only with testnet/mainnet.
PAPER_TRADING=true


# =============================================================================
# TRADING SYMBOLS
# =============================================================================
# "ALL" = trade every perpetual listed on Hyperliquid (500+ symbols)
# Or provide a comma-separated list: BTC,ETH,SOL,DOGE
TRADING_SYMBOLS=ALL

# Legacy single-symbol fallback (used if TRADING_SYMBOLS is not set)
TRADING_SYMBOL=SOL


# =============================================================================
# CAPITAL & RISK
# =============================================================================
# Starting capital in USD (paper mode) or your account balance ceiling
INITIAL_CAPITAL=1000.0

# Maximum fraction of capital per position (0.12 = 12%)
MAX_POSITION_PCT=0.12

# Minimum fraction of capital per position (0.05 = 5%)
MIN_POSITION_PCT=0.05

# Maximum daily loss in USD before the bot pauses all new entries
DAILY_LOSS_LIMIT=50.0

# Health factor floor — positions are reduced if portfolio health drops below this
MIN_HEALTH_FACTOR=2.0

# Maximum simultaneous open trades
# MAX_CONCURRENT_TRADES=3   # hard-coded at 3; change in src/config.rs if needed


# =============================================================================
# HYPERLIQUID — Required for testnet/mainnet
# Get your keys: https://app.hyperliquid.xyz → Portfolio → API
#
# HYPERLIQUID_KEY     = API key shown in the HL dashboard
# HYPERLIQUID_SECRET  = API secret (only shown once — copy it immediately)
# HYPERLIQUID_WALLET_ADDRESS = Your Ethereum wallet address (0x…)
#                       This is the address linked to your HL account.
#                       Used for clearinghouse state queries and order signing.
# =============================================================================
HYPERLIQUID_KEY=
HYPERLIQUID_SECRET=
HYPERLIQUID_WALLET_ADDRESS=0x

# Milliseconds between Hyperliquid HTTP requests (avoids 429 rate-limit errors)
# Increase to 2500+ if you see repeated 429s in the logs.
HYPERLIQUID_RATE_LIMIT_MS=1800

# Builder code: your Hyperliquid builder address (0x…)
# Every order will embed this so you earn the builder fee.
# Leave blank in paper mode. Required to earn revenue in testnet/mainnet.
# Register at: https://app.hyperliquid.xyz → Referrals & Builder
BUILDER_CODE=

# Builder fee in basis points (1–3). 1 = minimum / Pro reward tier.
# Hyperliquid hard cap is 3 bps. Values above 3 are clamped automatically.
BUILDER_FEE_BPS=1

# Referral slug — displayed to users so they sign up via your link.
# Earns 10% fee rebate on all trading volume from referred users.
# Register at: https://app.hyperliquid.xyz → Referrals
REFERRAL_CODE=TRADINGBOTS


# =============================================================================
# ANTHROPIC — AI signal analysis (Claude)
# Required for the AI-enhanced signal engine.
# Get a free key: https://console.anthropic.com → API Keys
# Free tier: $5 trial credit. Paid: pay-as-you-go (very cheap for this use).
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-


# =============================================================================
# LUNARCRUSH — Social sentiment data
# Required for sentiment-driven signals.
# Get a free key: https://lunarcrush.com/developers/api/authentication
# Free plan: 1,000 credits/day — sufficient for paper trading.
# =============================================================================
LUNARCRUSH_API_KEY=


# =============================================================================
# COINGECKO — BTC dominance & macro data
# Optional but recommended — prevents rate-limit errors on the free public API.
# Get a free Demo key: https://www.coingecko.com/en/api
# Free Demo plan: 10,000 calls/month — more than enough.
# After sign-up: Dashboard → Developer → Demo API Key
# =============================================================================
COINGECKO_API_KEY=CG-


# =============================================================================
# DATABASE
# SQLite (default, no setup required) or PostgreSQL for production.
#
# SQLite (recommended for single-server deployments):
#   DATABASE_URL=sqlite:///var/data/tradingbots.db
#
# PostgreSQL:
#   DATABASE_URL=postgresql://user:password@localhost:5432/tradingbots
# =============================================================================
DATABASE_URL=sqlite:///var/data/tradingbots.db


# =============================================================================
# SESSION SECRET — HTTP session cookie signing
# Generate a strong random value: openssl rand -hex 32
# If not set, a random UUID is used (sessions reset on every restart).
# =============================================================================
SESSION_SECRET=


# =============================================================================
# ADMIN PANEL — HTTP Basic Auth
# Protects all /admin/* routes. Username is always "admin".
# Leave blank to disable the admin panel (returns 503).
# Generate: openssl rand -hex 16
# =============================================================================
ADMIN_PASSWORD=


# =============================================================================
# STRIPE — Subscription billing ($19.99/month Pro plan)
# Required only if you want to charge users via credit card.
# Sign up: https://dashboard.stripe.com → Developers → API Keys
#
# STRIPE_SECRET_KEY     = sk_live_… (production) or sk_test_… (testing)
# STRIPE_WEBHOOK_SECRET = whsec_… — verifies webhook authenticity
#                         Get from: Stripe Dashboard → Webhooks → your endpoint
# STRIPE_PRICE_ID       = price_… — the Price ID for your $19.99/month product
#                         Create at: Products → Add Product → Add Price
# STRIPE_PROMO_PRICE_ID = price_… — optional $9.95 first-month introductory price
#                         Create a separate Price at the discounted amount
# =============================================================================
STRIPE_SECRET_KEY=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_ID=price_
STRIPE_PROMO_PRICE_ID=price_


# =============================================================================
# PRIVY — Consumer authentication (wallet + social login)
# Required if you want per-user auth on /app/* routes.
# Sign up: https://dashboard.privy.io → Create App
# PRIVY_APP_ID = your app's ID from the Privy dashboard
# Leave blank for single-operator deployments (no per-user auth).
# =============================================================================
PRIVY_APP_ID=

# WalletConnect Cloud project ID — enables mobile wallet login
# (MetaMask Mobile, Rainbow, Coinbase Wallet, etc.)
# Get a free ID: https://cloud.walletconnect.com → Create Project
# Leave blank to support only desktop browser-extension wallets.
WALLETCONNECT_PROJECT_ID=


# =============================================================================
# RESEND — Transactional email
# Required for welcome emails, trade alerts, and billing receipts.
# Sign up: https://resend.com → API Keys (100 emails/day free)
# EMAIL_FROM format: "Display Name <address@yourdomain.com>"
# =============================================================================
RESEND_API_KEY=re_
EMAIL_FROM=TradingBots.fun <hello@tradingbots.fun>


# =============================================================================
# APPLE PAY — Domain verification (optional)
# Required only if you enable Apple Pay in your Stripe account.
# Get from: Stripe Dashboard → Settings → Payment methods → Apple Pay →
#           Add new domain → copy the file contents here.
# =============================================================================
# APPLE_PAY_DOMAIN_ASSOC=


# =============================================================================
# COINZILLA — Display ads (shown only to Free/Trial users)
# Optional. When unset, no ads are rendered anywhere.
# Sign up as publisher: https://publishers.coinzilla.io
# After approval: My Sites → Zone → Get Code → copy the numeric zone ID
# =============================================================================
# COINZILLA_ZONE_ID=


# =============================================================================
# BRIDGE — Automated withdrawals (advanced)
# Minimum USD amount for automated bridge withdrawals.
# Trusted destination Arbitrum addresses (comma-separated).
# =============================================================================
BRIDGE_MIN_WITHDRAW_USD=50.0
# BRIDGE_TRUSTED_DESTINATIONS=0xYourArbitrumAddress1,0xYourArbitrumAddress2


# =============================================================================
# LOGGING
# =============================================================================
# Set to "info" for normal operation, "debug" for verbose output.
# Without this, info!() logs are silently discarded.
# On VPS: add to /etc/environment, then: systemctl restart tradingbots
RUST_LOG=info


# =============================================================================
# BINANCE (optional — legacy price feed fallback)
# Not required for normal operation. Used as a fallback data source.
# Get from: https://www.binance.com/en/my/settings/api-management
# =============================================================================
# BINANCE_API_KEY=
