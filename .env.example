# ══════════════════════════════════════════════════════════════════════════════
# TradingBots.fun — environment variables
#
# Copy values into /etc/environment on the VPS (loaded by systemd).
# This file documents the shape — never commit real secrets.
#
# On the VPS:
#   nano /etc/environment         ← edit secrets here
#   systemctl restart tradingbots    ← pick up changes
#
# DATABASE_URL is written automatically by:  ./deploy.sh --provision
# OLLAMA_BASE_URL is written automatically by: ./deploy.sh --provision-ollama
# ══════════════════════════════════════════════════════════════════════════════

# ── Database (written by --provision) ─────────────────────────────────────────
DATABASE_URL=postgresql://tradingbots:CHANGE_ME@127.0.0.1/tradingbots

# ══════════════════════════════════════════════════════════════════════════════
# AI PROVIDER
#
# The bot uses a single AI_PROVIDER setting to route trade-analysis prompts.
# Operators choose whichever provider fits their cost/privacy/latency needs.
#
# AI_PROVIDER options:
#   claude      — Anthropic Claude (default, best reasoning quality)
#   openai      — OpenAI GPT-4o / GPT-4o-mini
#   xai         — xAI Grok (OpenAI-compatible API)
#   openrouter  — OpenRouter (aggregates 200+ models, set AI_MODEL accordingly)
#   ollama      — Self-hosted Ollama on a DEDICATED separate droplet
#                 ⚠ Do NOT run Ollama on the trading-bot VPS — it starves
#                   the bot of memory and causes missed trade execution.
#                   Provision with: ./deploy.sh --provision-ollama
#
# AI_MODEL — model identifier for the chosen provider.  Leave blank for defaults:
#   claude      → claude-haiku-4-5-20251001  (fast + cheap for trade summaries)
#   openai      → gpt-4o-mini
#   xai         → grok-2
#   openrouter  → openai/gpt-4o-mini  (or any model slug from openrouter.ai/models)
#   ollama      → llama3.2
#
# AI_API_KEY — API key for cloud providers (not needed for ollama).
#
# OLLAMA_BASE_URL — URL of the Ollama droplet (ollama provider only).
#   Written automatically by ./deploy.sh --provision-ollama
# ══════════════════════════════════════════════════════════════════════════════
AI_PROVIDER=claude
AI_MODEL=claude-haiku-4-5-20251001
AI_API_KEY=your-anthropic-api-key-here

# Uncomment one of these to use a different provider instead:
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini
# AI_API_KEY=sk-proj-...

# AI_PROVIDER=xai
# AI_MODEL=grok-2
# AI_API_KEY=xai-...

# AI_PROVIDER=openrouter
# AI_MODEL=openai/gpt-4o-mini        # or: anthropic/claude-haiku-4-5, meta-llama/llama-3.2-3b-instruct, etc.
# AI_API_KEY=sk-or-v1-...

# AI_PROVIDER=ollama
# AI_MODEL=llama3.2                  # or: mistral, deepseek-r1:7b, etc.
# OLLAMA_BASE_URL=http://YOUR_OLLAMA_DROPLET_IP:11434   # written by --provision-ollama

# ── Trading ────────────────────────────────────────────────────────────────────
# =============================================================================

# TRADING MODE
# Options: testnet (free, no risk), mainnet (real money)
MODE=testnet

# TRADING PARAMETERS
TRADING_SYMBOL=SOL
INITIAL_CAPITAL=100
MAX_POSITION_PCT=0.15
MAX_LEVERAGE=15.0
DAILY_LOSS_LIMIT=30.0
MIN_HEALTH_FACTOR=2.0

# =============================================================================
# BINANCE API (CEX ORDER BOOK MONITORING)
# Get keys: https://www.binance.com/en/account/api-management
# =============================================================================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# =============================================================================
# HYPERLIQUID API (DEX TRADING - REAL ORDERS)
# Get keys: https://app.hyperliquid.xyz (Settings → API)
# WARNING: This will execute REAL trades with real money!
# =============================================================================
HYPERLIQUID_KEY=your_hyperliquid_key_here
HYPERLIQUID_SECRET=your_private_key_hex_here
HYPERLIQUID_WALLET_ADDRESS=0xYourWalletAddressHere

# =============================================================================
# BUILDER CODE (PLATFORM REVENUE — OPERATORS ONLY)
# Platform wallet address that earns Hyperliquid builder fees on every order.
# Set once on the server; users never see or interact with this field.
# Every order placed by any user through this platform credits this address.
# Leave blank for pure paper-trading deployments.
# =============================================================================
BUILDER_CODE=0xYourPlatformBuilderAddressHere

# =============================================================================
# REFERRAL CODE (AFFILIATE REVENUE — OPERATORS ONLY)
# Your Hyperliquid referral slug registered at app.hyperliquid.xyz.
# Displayed in the consumer /app page so new users sign up via your link:
#   https://app.hyperliquid.xyz/join/TRADINGBOTS
# Earns 10% of trading fee rebates from all referred users — ongoing passive
# income on top of builder fees, completely invisible to end users.
# Register your code at: https://app.hyperliquid.xyz (Profile → Referrals)
# =============================================================================
REFERRAL_CODE=TRADINGBOTS

# =============================================================================
# STRIPE BILLING (SUBSCRIPTION — OPERATORS ONLY)
# Required to enable the $19.99/month Pro subscription flow.
# Get keys: https://dashboard.stripe.com/apikeys
#
# STRIPE_SECRET_KEY      — server-side secret key (sk_live_… or sk_test_…)
# STRIPE_WEBHOOK_SECRET  — endpoint signing secret (whsec_…)
#                          Set up at: Dashboard → Developers → Webhooks
#                          Listen for: checkout.session.completed,
#                                      customer.subscription.deleted,
#                                      invoice.payment_failed
# STRIPE_PRICE_ID        — recurring price ID for the Pro plan (price_…)
#                          Create at: Dashboard → Products → Add product
# =============================================================================
STRIPE_SECRET_KEY=sk_test_yourKeyHere
STRIPE_WEBHOOK_SECRET=whsec_yourWebhookSecretHere
STRIPE_PRICE_ID=price_yourPriceIdHere

# =============================================================================
# APPLE PAY + GOOGLE PAY (AUTOMATIC VIA STRIPE CHECKOUT)
# Apple Pay and Google Pay are shown automatically in Stripe Checkout when the
# user's device supports them — no extra code is needed.
#
# Apple Pay requires domain verification.  One-time setup (~2 minutes):
#   1. Stripe Dashboard → Settings → Payment methods → Apple Pay
#   2. Click "Add new domain" and enter your domain (e.g. yourdomain.com)
#   3. Stripe shows a verification file — paste its full CONTENTS below
#      (the file is ~3KB of hexadecimal text, all on one line)
#   4. Deploy.  Apple Pay button appears automatically in Stripe Checkout.
#
# Google Pay needs no domain verification — it activates automatically.
# =============================================================================
APPLE_PAY_DOMAIN_ASSOC=paste_the_full_contents_of_the_stripe_verification_file_here

# =============================================================================
# PRIVY AUTHENTICATION (MULTI-TENANT CONSUMER LOGIN — OPERATORS ONLY)
# Required to enable per-user login on /app.  When unset, /app falls back to
# single-operator mode (no login required, shows operator's own state).
#
# PRIVY_APP_ID  — your Privy App ID from https://dashboard.privy.io
#                 Enables the /login page and JWT verification for /app/* routes.
# SESSION_SECRET — 32-byte hex key for signing session cookies.
#                  Generate: openssl rand -hex 32
#                  ⚠ If not set, a random key is generated at startup and
#                    sessions will not survive server restarts.
# =============================================================================
PRIVY_APP_ID=your-privy-app-id-here
SESSION_SECRET=your-32-byte-hex-session-secret-here

# =============================================================================
# ADMIN PANEL (OPERATOR ONLY)
# Protects /admin and /admin/users with HTTP Basic Auth.
# Username is always "admin"; set a strong password here.
# Generate: openssl rand -hex 16
# Leave blank to disable the admin panel entirely (returns 503).
# =============================================================================
ADMIN_PASSWORD=your-admin-password-here

# =============================================================================
# DATABASE
# Default: Local PostgreSQL on localhost
# Production: Use managed PostgreSQL service
# =============================================================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tradingbots

# =============================================================================
# LOGGING
# Options: debug, info, warn, error
# Use 'debug' for troubleshooting, 'info' for production
# =============================================================================
RUST_LOG=info

# =============================================================================
# OPTIONAL: WHALE TRACKING (GMGN)
# Get API key: https://gmgn.ai (optional, free tier available)
# =============================================================================
GMGN_API_KEY=optional_gmgn_key_here

# =============================================================================
# SERVER
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# =============================================================================
# DEPLOYMENT ENVIRONMENT
# =============================================================================
DOCKER_IMAGE_TAG=latest
CONTAINER_NAME=tradingbots-app

# =============================================================================
# SAFETY LIMITS (ENFORCED - DO NOT CHANGE)
# =============================================================================
# These values are hardcoded and cannot be overridden in production
# Max Position: 15% of capital per trade
# Max Leverage: 15x (scaled by volatility, actual may be lower)
# Min Health Factor: 2.0 (prevents liquidation)
# Daily Loss Limit: $30 (stops trading if hit)
# =============================================================================
