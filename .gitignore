# Environment variables (NEVER commit these!)
.env
.env.local
.env.*.local

# Configuration files with secrets
deployment.toml
config.toml
secrets.json

# Build artifacts
/target
/dist
Cargo.lock

# JS login bundle build deps (built output is committed to static/)
js/node_modules/
js/package-lock.json

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs — ignore runtime/scratch logs but track CI audit logs in logs/ci/
# NOTE: git cannot negate a subdir of an ignored parent, so we list
# specific subdirs to ignore rather than ignoring logs/ wholesale.
/var/log/
logs/tmp/
logs/*.log

# Backups
*.backup
*.bak
*~

# OS specific
.DS_Store
Thumbs.db

# Testing
test-results/
coverage/

# Cache
.cache/
*.cache

# API keys and credentials (extra safety)
**/api_key
**/secret_key
**/credentials
**/auth_token

# Claude internal workspace files
.claude/
fix_main.py

# Production environment config (contains DO managed DB credentials)
.tradingbots-prod.env
.tradingbots-db.env
